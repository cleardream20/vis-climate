# 复制为 .env.local 后按需修改（Vite 仅暴露以 VITE_ 开头的变量）
# 热浪档使用 public/data/real/t2m_{year}.json 真实格点；缺文件或请求失败时自动回退演示场
# 有 public/data/real/*.json 时建议 true；无文件时会自动回退演示场
VITE_USE_REAL_GRID=true
# 仅当使用未重导的旧 JSON（无 meta.gridLayout）且热力图与地图错位时尝试：
# VITE_REAL_GRID_FLIP_ROWS=true
# VITE_REAL_GRID_FLIP_COLS=true
# 热力 image 条带数（1～16，默认代码里为 4）：减轻大范围单纹理在 MapLibre 下的轻微扭曲
# VITE_HEAT_RASTER_STRIPS=4
# 整块热力相对底图南北微调（度），例如 -0.05
# VITE_HEAT_RASTER_LAT_SHIFT=0
# 国界 / 省界初始是否显示（运行时可在顶栏勾选；false|0|no 为关）
# VITE_MAP_SHOW_COUNTRY=true
# VITE_MAP_SHOW_PROVINCE=true
